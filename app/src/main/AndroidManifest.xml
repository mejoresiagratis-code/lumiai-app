<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Foreground service so the torch survives backgrounding (added with the service in Fase 1). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- POST_NOTIFICATIONS needed on Android 13+ for the torch service notification. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Torch availability is optional: app still runs in Screen mode on devices without a flash. -->
    <uses-feature android:name="android.hardware.camera.flash" android:required="false" />

    <application
        android:name=".LumiAiApplication"
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.LumiAi.Starting">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.LumiAi.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
